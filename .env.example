# Copy this file to .env and fill in values before running.
# .env is gitignored. Never commit real credentials.

# Logical owner ID. Placeholder for future multi-user support.
# Leave as "default" for single-user installations.
OWNER_ID=default

# Backup configuration
RCLONE_REMOTE=gdrive
BACKUP_PATH=em-journal-backups
# Hour (0-23, local time) to run the daily backup
BACKUP_HOUR=3

# Staleness thresholds (days)
ALLOCATION_STALE_DAYS=45
ONE_ON_ONE_STALE_DAYS=14

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
